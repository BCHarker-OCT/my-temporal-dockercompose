{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "title": "Temporal Shard IO Concurrency Dashboard v1.1.0 (SQL only — not applicable to Cassandra)",
  "uid": "temporal-shard-io-v1",
  "version": 2,
  "schemaVersion": 38,
  "tags": ["temporal", "prometheus", "history", "shard"],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Shard IO Semaphore",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p99 wait time to acquire the shard IO semaphore for high-priority (active workflow) traffic. Measures time from acquire attempt to completion, including queue wait and DB round-trip hold time. Elevated values indicate writes are queuing within individual shards. Compare with Persistence Write Latency (Row 2) to determine root cause.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.02 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile($p, sum(rate(semaphore_latency_bucket{operation=\"ShardInfo\",priority=\"0\"}[$__rate_interval])) by (le))",
          "legendFormat": "p{{ quantile }} high-priority",
          "refId": "A"
        }
      ],
      "title": "Shard IO Semaphore Latency (High Priority)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of semaphore acquisition failures — callers whose context deadline expired before a slot became available. Any non-zero rate means active work is being dropped. A sustained or growing rate alongside elevated semaphore latency is urgent: callers are not just waiting longer, they are giving up.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.001 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(semaphore_failures{operation=\"ShardInfo\"}[$__rate_interval]))",
          "legendFormat": "semaphore failures/s",
          "refId": "A"
        }
      ],
      "title": "Shard IO Semaphore Failures",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 102,
      "title": "Practical Ceiling — Max Safe shardIOConcurrency Value Per Pod",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "The practical ceiling for history.shardIOConcurrency per pod, calculated as:\n\n  persistence_sql_max_open_conn / numshards_gauge\n\nThis is the maximum value that can be set before the SQL connection pool risks exhaustion under full burst load — when every shard on the pod has the maximum number of writes in-flight simultaneously.\n\nDo not set history.shardIOConcurrency above this value. In practice, stop incrementing when semaphore_latency stops improving between steps — the DB throughput ceiling is reached before the pool ceiling in most clusters. For most production SQL clusters this happens between 4 and 8.\n\nEach line represents one history pod (by instance label). If pods own different numbers of shards (during rolling restarts or rebalancing), lines will diverge temporarily.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "max safe value",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "dashed" }
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "persistence_sql_max_open_conn{db_kind=\"main\"} / on(instance) group_left() numshards_gauge{operation=\"ShardController\"}",
          "legendFormat": "ceiling — {{ instance }}",
          "refId": "A"
        }
      ],
      "title": "Max Safe shardIOConcurrency Per Pod  (pool_size ÷ shards_per_pod)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 101,
      "title": "Persistence / DB Health — Prerequisite Check Before Raising shardIOConcurrency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p99 DB round-trip latency for the write operations gated by the shard IO semaphore. Use this panel together with Shard IO Semaphore Latency to determine root cause:\n\n• Semaphore latency HIGH + persistence latency LOW → serialization bottleneck, DB has headroom → consider raising history.shardIOConcurrency\n• Both HIGH → DB is saturated → fix DB first, do NOT raise shardIOConcurrency\n• Semaphore latency LOW + persistence latency HIGH → DB is slow but semaphore is not the bottleneck",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile($p, sum(rate(persistence_latency_bucket{operation=\"UpdateWorkflowExecution\"}[$__rate_interval])) by (le))",
          "legendFormat": "UpdateWorkflowExecution p{{ quantile }}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile($p, sum(rate(persistence_latency_bucket{operation=\"AddTasks\"}[$__rate_interval])) by (le))",
          "legendFormat": "AddTasks p{{ quantile }}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile($p, sum(rate(persistence_latency_bucket{operation=\"CreateWorkflowExecution\"}[$__rate_interval])) by (le))",
          "legendFormat": "CreateWorkflowExecution p{{ quantile }}",
          "refId": "C"
        }
      ],
      "title": "Persistence Write Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "SQL connection pool utilization ratio (in_use / max_open). Approaching 1.0 means the pool is exhausted — new write requests queue waiting for a free connection.\n\n• < 0.5: ample headroom, safe to raise shardIOConcurrency\n• 0.5–0.8: moderate utilization, monitor carefully after raising\n• > 0.8: pool under pressure, raising shardIOConcurrency may push it to exhaustion\n• Approaching 1.0: do NOT raise shardIOConcurrency\n\nAlso shows persistence_errors_resource_exhausted rate — any non-zero value indicates the DB or server is actively rejecting requests.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "resource exhausted errors/s" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "persistence_sql_in_use / persistence_sql_max_open_conn",
          "legendFormat": "connection pool utilization ({{ db_kind }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(persistence_errors_resource_exhausted[$__rate_interval]))",
          "legendFormat": "resource exhausted errors/s",
          "refId": "B"
        }
      ],
      "title": "SQL Connection Pool Utilization & Resource Exhausted Errors",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "style": "dark",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(service_requests{namespace!=\"_unknown_\"}, namespace)",
        "hide": 0,
        "includeAll": true,
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(service_requests{namespace!=\"_unknown_\"}, namespace)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "0.99", "value": "0.99" },
        "hide": 0,
        "includeAll": false,
        "label": "Percentile",
        "multi": false,
        "name": "p",
        "options": [
          { "selected": false, "text": "0.50", "value": "0.50" },
          { "selected": false, "text": "0.75", "value": "0.75" },
          { "selected": false, "text": "0.90", "value": "0.90" },
          { "selected": false, "text": "0.95", "value": "0.95" },
          { "selected": true, "text": "0.99", "value": "0.99" },
          { "selected": false, "text": "0.999", "value": "0.999" }
        ],
        "query": "0.50,0.75,0.90,0.95,0.99,0.999",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "weekStart": ""
}
